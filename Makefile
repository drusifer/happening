SHELL := /bin/bash

FLUTTER_SDK  := .flutter/flutter
FLUTTER      := $(abspath $(FLUTTER_SDK)/bin/flutter)
APP_DIR      := app

# Sentinel: regenerated by `flutter pub get`. Depends on pubspec files.
# Make skips pub get unless pubspec.yaml or pubspec.lock changed.
PUB_STAMP    := $(APP_DIR)/.dart_tool/package_config.json

# ── Bootstrap ────────────────────────────────────────────────────────────────

# Human-readable entry point — no-ops if deps are current.
.PHONY: setup
setup: $(PUB_STAMP)

# Fetch pub deps only when pubspec files are newer than the stamp.
$(PUB_STAMP): $(APP_DIR)/pubspec.yaml $(APP_DIR)/pubspec.lock $(FLUTTER_SDK)/bin/flutter
	cd $(APP_DIR) && $(FLUTTER) pub get

# Download Flutter SDK only when the binary is absent.
$(FLUTTER_SDK)/bin/flutter:
	./scripts/setup.sh

# ── Dev ──────────────────────────────────────────────────────────────────────
.PHONY: run
run: $(PUB_STAMP)
	cd $(APP_DIR) && $(FLUTTER) run -d linux

# ── Test ─────────────────────────────────────────────────────────────────────
.PHONY: test
test: $(PUB_STAMP)
	cd $(APP_DIR) && $(FLUTTER) test --coverage

.PHONY: test-watch
test-watch: $(PUB_STAMP)
	cd $(APP_DIR) && $(FLUTTER) test --coverage --watch

# ── Build ────────────────────────────────────────────────────────────────────
.PHONY: build-linux build-macos build-windows
build-linux: $(PUB_STAMP)
	cd $(APP_DIR) && $(FLUTTER) build linux --release

build-macos: $(PUB_STAMP)
	cd $(APP_DIR) && $(FLUTTER) build macos --release

build-windows: $(PUB_STAMP)
	cd $(APP_DIR) && $(FLUTTER) build windows --release

# ── Quality ──────────────────────────────────────────────────────────────────
.PHONY: format analyze
format: $(PUB_STAMP)
	cd $(APP_DIR) && $(FLUTTER) format lib/ test/

analyze: $(PUB_STAMP)
	cd $(APP_DIR) && $(FLUTTER) analyze

# ── Clean ────────────────────────────────────────────────────────────────────
.PHONY: clean distclean
clean:
	cd $(APP_DIR) && $(FLUTTER) clean

distclean: clean
	rm -rf .flutter/

# ── Help ─────────────────────────────────────────────────────────────────────
.PHONY: help
help:
	@echo "Happening — Makefile targets"
	@echo ""
	@echo "  make setup        Install Flutter SDK + fetch pub deps (skips if up to date)"
	@echo "  make run          Run app on Linux desktop"
	@echo "  make test         Run all tests with coverage"
	@echo "  make build-linux  Release build for Linux"
	@echo "  make build-macos  Release build for macOS"
	@echo "  make format       Format all Dart source"
	@echo "  make analyze      Run Dart analyzer"
	@echo "  make clean        Remove build artifacts"
	@echo "  make distclean    Remove build artifacts + Flutter SDK"
